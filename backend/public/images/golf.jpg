wOQAAAADJPgWO","fr":"","query":"golf image"}}}}</script><style type='text/css'>
      .frame #logo
      {
          background-image:url('https://s.yimg.com/pv/static/img/image-pc-framepage-sprite-201305072346.png');
          *background-image:url('https://s.yimg.com/pv/static/img/image-pc-framepage-sprite-IE6-201305072346.png');
      }

      .sprite, .slideshows .close, .slideshows .search, .nav-arrow, .fstoggle, .sa-clear, .sa-search-dft, .sa-search-clk, .frame #logo, #share-widget .ext, .imginfo span.flk, .imginfo span.omg, .imginfo span.fbk, .logo-home, #share #tw i
      {
          background-image: url("https://s.yimg.com/pv/static/img/image-pc-framepage-sprite-201305072346.png");
          *background-image: url('https://s.yimg.com/pv/static/img/image-pc-framepage-sprite-IE6-201305072346.png');
      }

    /* tablet */
    .tablet .close, .tablet .search-toggle, .tablet .nav-arrow, .tablet .playpod .info-panel .action-buttons span.sprite, .tablet .frame .ygbt, .tablet #logo
    {
        background-image: url('https://s.yimg.com/pv/static/img/srp-image-tablet-framepage-sprite-non-retina-201307240913.png');
    }

    @media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {

        .tablet .close, .tablet .search-toggle, .tablet .nav-arrow, .tablet .playpod .info-panel .action-buttons span.sprite, .tablet .frame .ygbt, .tablet #logo
        {
            background-image: url('https://s.yimg.com/pv/static/img/srp-image-tablet-framepage-sprite-retina-201308290029.png');
        }
    }

